# Render Web Service and Worker
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
ADMIN_API_TOKEN=replace-with-a-long-random-token
ALLOWED_ORIGINS=https://your-project.vercel.app
CLOUD_DEPLOYMENT=1

# Optional local PostgreSQL settings (desktop mode only)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=postgres
